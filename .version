# Canonical version for the satelle binary. The release workflow reads
# satelle.version to derive the release tag (v<version>); the version + build
# timestamp are baked into the binary via -ldflags at build time. .version is a
# build-time source file, NEVER deployed in release artifacts.

satelle.version: 0.0.4
satelle.build: 2026-06-27-05-58-25
