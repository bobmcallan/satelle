# Canonical version for the satelle binary — the SINGLE source of truth. The
# release workflow derives the release tag (v<satelle.version>) from this value,
# and every build (release CI and local `make build`) bakes it into the binary via
# -ldflags alongside the commit SHA and a build-time-GENERATED timestamp. There is
# no hand-edited build time: the timestamp is generated at build (date -u), so a
# build can never ship a stale one. .version is a build-time source file, NEVER
# deployed in release artifacts. Cutting a release = bump this one value.

satelle.version: 0.0.11
